{
  "name": "@dustinvk/lore-dashboard",
  "version": "0.1.0",
  "description": "Build tool that reads a lore/ directory and emits a static dashboard.",
  "type": "module",
  "bin": {
    "lore-dashboard": "bin/lore-dashboard.js"
  },
  "files": [
    "bin",
    "src",
    "astro.config.mjs"
  ],
  "scripts": {
    "dev": "node bin/lore-dashboard.js dev",
    "build": "node bin/lore-dashboard.js build --src tests/fixtures/lore --out .test-dist",
    "test": "node --test tests/fixture-check.mjs"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DustinVK/lore.git",
    "directory": "packages/lore-dashboard"
  },
  "license": "MIT"
}
