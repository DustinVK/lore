---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const allQ = await getCollection('questions');

const withContent = await Promise.all(
  allQ.map(async q => ({ q, rendered: await render(q) }))
);

function byDateDesc(a: { q: { data: { asked_date: string } } }, b: { q: { data: { asked_date: string } } }) {
  return b.q.data.asked_date.localeCompare(a.q.data.asked_date);
}

const open = withContent.filter(x => x.q.data.status === 'open').sort(byDateDesc);
const resolved = withContent.filter(x => x.q.data.status === 'resolved').sort(byDateDesc);

const allAreas = [...new Set(allQ.flatMap(q => q.data.areas))].sort();
---
<Base pageTitle="Questions">
  <h1>Questions</h1>

  <div class="filter-row" id="q-filters">
    <select id="q-area-filter" aria-label="Filter by area">
      <option value="">All areas</option>
      {allAreas.map(a => <option value={a}>{a}</option>)}
    </select>
    <input
      type="text"
      id="q-search"
      placeholder="Search questions..."
      aria-label="Search questions"
      style="flex: 1; min-width: 140px;"
    />
  </div>

  <div class="tabs">
    <button class="tab-btn active" data-tab="open" type="button">
      Open <span class="tab-count">({open.length})</span>
    </button>
    <button class="tab-btn" data-tab="resolved" type="button">
      Resolved <span class="tab-count">({resolved.length})</span>
    </button>
  </div>

  <div id="tab-open" class="tab-panel active">
    {open.length === 0 ? (
      <p class="empty">No open questions.</p>
    ) : (
      <ul class="question-list">
        {open.map(({ q, rendered }) => {
          const { Content } = rendered;
          const hasBody = !!q.body?.trim();
          return (
            <li
              class="question-card"
              data-areas={q.data.areas.join(',')}
              data-question={q.data.question.toLowerCase()}
            >
              <div class="question-id">{q.data.id}</div>
              <div class="question-text">{q.data.question}</div>
              <div class="question-meta">
                <span class="entry-date">{q.data.asked_date}</span>
                {q.data.areas.map(a => <span class="chip chip--area">{a}</span>)}
              </div>
              {hasBody && (
                <details class="question-details">
                  <summary>Details</summary>
                  <div class="question-body"><Content /></div>
                </details>
              )}
            </li>
          );
        })}
      </ul>
    )}
    <p class="no-results" data-panel="open" style="display:none;">No matching questions.</p>
  </div>

  <div id="tab-resolved" class="tab-panel">
    {resolved.length === 0 ? (
      <p class="empty">No resolved questions yet.</p>
    ) : (
      <ul class="question-list">
        {resolved.map(({ q, rendered }) => {
          const { Content } = rendered;
          const hasBody = !!q.body?.trim();
          return (
            <li
              class="question-card"
              data-areas={q.data.areas.join(',')}
              data-question={q.data.question.toLowerCase()}
            >
              <div class="question-id">{q.data.id}</div>
              <div class="question-text">{q.data.question}</div>
              <div class="question-meta">
                <span class="entry-date">{q.data.asked_date}</span>
                {q.data.areas.map(a => <span class="chip chip--area">{a}</span>)}
              </div>
              {q.data.resolution && (
                <div class="question-resolution">
                  {q.data.resolution_slug
                    ? <><span>Resolved: </span><a href={`/log/${q.data.resolution_slug}`}>{q.data.resolution}</a></>
                    : <span>Resolved: {q.data.resolution}</span>
                  }
                </div>
              )}
              {hasBody && (
                <details class="question-details">
                  <summary>Details</summary>
                  <div class="question-body"><Content /></div>
                </details>
              )}
            </li>
          );
        })}
      </ul>
    )}
    <p class="no-results" data-panel="resolved" style="display:none;">No matching questions.</p>
  </div>
</Base>

<script is:inline>
  (function () {
    const areaFilter = document.getElementById('q-area-filter');
    const searchInput = document.getElementById('q-search');
    const tabBtns = Array.from(document.querySelectorAll('.tab-btn'));
    const tabPanels = Array.from(document.querySelectorAll('.tab-panel'));

    let activeTab = 'open';

    function switchTab(tab) {
      activeTab = tab;
      tabBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.tab === tab);
      });
      tabPanels.forEach(panel => {
        panel.classList.toggle('active', panel.id === 'tab-' + tab);
      });
      applyFilter();
    }

    function applyFilter() {
      const area = areaFilter ? areaFilter.value : '';
      const search = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const panel = document.getElementById('tab-' + activeTab);
      if (!panel) return;

      const cards = Array.from(panel.querySelectorAll('.question-card'));
      let visible = 0;
      for (const card of cards) {
        const cardAreas = card.dataset.areas ? card.dataset.areas.split(',') : [];
        const cardQuestion = card.dataset.question || '';
        const matchArea = !area || cardAreas.includes(area);
        const matchSearch = !search || cardQuestion.includes(search);
        const show = matchArea && matchSearch;
        card.hidden = !show;
        if (show) visible++;
      }

      const noResult = panel.querySelector('.no-results');
      if (noResult) noResult.style.display = (cards.length > 0 && visible === 0) ? 'block' : 'none';
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });

    [areaFilter, searchInput].forEach(el => {
      if (el) el.addEventListener('input', applyFilter);
    });

    applyFilter();
  })();
</script>
