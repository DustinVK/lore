---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allEntries = await getCollection('log');

const sorted = allEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const allAreas = [...new Set(allEntries.flatMap(e => e.data.areas))].sort();
const allTopics = [...new Set(allEntries.flatMap(e => e.data.topics))].sort();

const activeCount = allEntries.filter(e => e.data.status === 'active').length;
const retiredCount = allEntries.filter(e => e.data.status !== 'active').length;
---
<Base pageTitle="Log">
  <h1>Log <span class="entry-count">{activeCount}</span></h1>

  <div class="filter-row" id="filters">
    <select id="area-filter" aria-label="Filter by area">
      <option value="">All areas</option>
      {allAreas.map(a => <option value={a}>{a}</option>)}
    </select>
    <select id="topic-filter" aria-label="Filter by topic">
      <option value="">All topics</option>
      {allTopics.map(t => <option value={t}>{t}</option>)}
    </select>
    <input
      type="text"
      id="search-filter"
      placeholder="Search titles..."
      aria-label="Search titles"
      style="flex: 1; min-width: 120px;"
    />
    {retiredCount > 0 && (
      <label>
        <input type="checkbox" id="retired-toggle" />
        Show superseded
      </label>
    )}
  </div>

  <p class="no-results" id="no-results" style="display:none;">No matching entries.</p>

  <ul class="entry-list" id="entry-list">
    {sorted.map(e => {
      const retired = e.data.status !== 'active';
      return (
        <li
          class:list={['entry-card', retired && 'entry-card--retired']}
          data-areas={e.data.areas.join(',')}
          data-topics={e.data.topics.join(',')}
          data-status={e.data.status}
          data-title={e.data.title.toLowerCase()}
        >
          <a class="entry-title" href={`/log/${e.id}`}>{e.data.title}</a>
          <div class="entry-meta">
            <span class="entry-date">{e.data.date}</span>
            {retired && (
              <span class:list={['status-badge', `status-badge--${e.data.status}`]}>
                {e.data.status}
              </span>
            )}
            {e.data.areas.map(a => <span class="chip chip--area">{a}</span>)}
            {e.data.topics.map(t => <span class="chip">{t}</span>)}
          </div>
        </li>
      );
    })}
  </ul>
</Base>

<style>
  h1 { display: flex; align-items: baseline; gap: 0.5rem; }
  .entry-count {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
  }
</style>

<script is:inline>
  (function () {
    const areaSelect = document.getElementById('area-filter');
    const topicSelect = document.getElementById('topic-filter');
    const searchInput = document.getElementById('search-filter');
    const retiredToggle = document.getElementById('retired-toggle');
    const list = document.getElementById('entry-list');
    const noResults = document.getElementById('no-results');

    if (!list) return;

    const cards = Array.from(list.querySelectorAll('.entry-card'));

    function applyFilter() {
      const area = areaSelect ? areaSelect.value : '';
      const topic = topicSelect ? topicSelect.value : '';
      const search = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const showRetired = retiredToggle ? retiredToggle.checked : false;

      let visible = 0;
      for (const card of cards) {
        const cardAreas = card.dataset.areas ? card.dataset.areas.split(',') : [];
        const cardTopics = card.dataset.topics ? card.dataset.topics.split(',') : [];
        const cardStatus = card.dataset.status || 'active';
        const cardTitle = card.dataset.title || '';
        const retired = cardStatus !== 'active';

        const matchArea = !area || cardAreas.includes(area);
        const matchTopic = !topic || cardTopics.includes(topic);
        const matchSearch = !search || cardTitle.includes(search);
        const matchRetired = showRetired || !retired;

        const show = matchArea && matchTopic && matchSearch && matchRetired;
        card.hidden = !show;
        if (show) visible++;
      }

      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    // Pre-set from URLSearchParams
    const params = new URLSearchParams(location.search);
    const areaParam = params.get('area');
    const topicParam = params.get('topic');
    if (areaParam && areaSelect) areaSelect.value = areaParam;
    if (topicParam && topicSelect) topicSelect.value = topicParam;

    // Wire listeners
    [areaSelect, topicSelect, searchInput, retiredToggle].forEach(el => {
      if (el) el.addEventListener('input', applyFilter);
    });

    applyFilter();
  })();
</script>
